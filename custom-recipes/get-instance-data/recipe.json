// This file is the descriptor for the Custom code recipe get-instance-data
{
    // Meta data for display purposes
    "meta": {
        // label: name of the recipe as displayed, should be short
        "label": "Get instance data",
        // description: longer string to help end users understand what this recipe does
        "description": "Scans all projects on this DSS instance and computes per-project usage stats (recipes, connections, scenarios, models, dashboards, collaborators, etc.).",
        // icon: must be one of the FontAwesome 5.15.4 icons, complete list here at https://fontawesome.com/v5/docs/
        "icon": "fas fa-puzzle-piece"
    },

    "kind": "PYTHON",
    

    // This recipe takes no input datasets - it reads the instance's projects
    // directly through the Dataiku API client - and produces a single output
    // dataset with one row of stats per project.

    "inputRoles": [],

    "outputRoles": [
        {
            "name": "instance_data2",
            "label": "Instance data",
            "description": "Per-project stats computed from the Dataiku API",
            "arity": "UNARY",
            "required": true,
            "acceptsDataset": true
        }
    ],

    "params": [],

    // The field "resourceKeys" holds a list of keys that allows to limit the number
    // of concurrent executions and activities triggered by this recipe.
    //
    // Administrators can configure the limit per resource key in the Administration > Settings > Flow build
    // screen.

    "resourceKeys": []

}
